#compdef wear
# zsh completion for `wear`. Put this file (named `_wear`) on your $fpath,
# e.g. ~/.local/share/zsh/site-functions/_wear, then `compinit`.

_wear() {
  local -a subs
  subs=(
    list current reload pick tweak gui set unset reset undo save
    random shuffle from from-color gallery demo dark light toggle
    doctor import export update show tweaks schema options get values help
  )

  if (( CURRENT == 2 )); then
    local -a themes
    themes=(${(f)"$(wear list 2>/dev/null)"})
    _describe -t commands 'wear command' subs
    _describe -t themes 'theme' themes
    return
  fi

  case "${words[2]}" in
    set|unset|get|is-overridden)
      if (( CURRENT == 3 )); then
        local -a keys
        keys=(${(f)"$(wear schema 2>/dev/null | grep -vE '^(##|$)' | cut -d'|' -f1)"})
        _describe -t keys 'property' keys
      fi ;;
    random|shuffle)
      _values 'section' accents colours shape feel bar popups everything ;;
    options)
      _values 'kind' icon_theme cursor_theme gtk_theme kvantum_theme wallpaper_shader ;;
    doctor)
      _arguments '--fix[auto-repair failing contrast]' ;;
    demo)
      _arguments '(-i --interval)'{-i,--interval}'[seconds per theme]:secs:' \
                 '(-l --loop)'{-l,--loop}'[loop forever]' \
                 '(-s --shuffle)'{-s,--shuffle}'[random order]' ;;
    from|from-image|import)
      _files ;;
    from-color|color)
      _arguments '--light[light variant]' '*:colour:' ;;
  esac
}
_wear "$@"
