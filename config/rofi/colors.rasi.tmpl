/* {{THEME_NAME}} — generated by `theme`. Do not edit; edit the .theme palette. */
* {
    bg:      #{{bg}}FA;
    bg-alt:  #{{bg_alt}}F0;
    fg:      #{{fg}};
    fg-alt:  #{{fg_dim}};
    accent:  #{{accent}};
    accent2: #{{accent2}};
    urgent:  #{{red}};
    on-accent: #{{on_accent}};

    /* structure (per-theme geometry) */
    t-radius:  {{radius}}px;
    t-border:  {{border_width}}px;
    t-font:    "{{font_ui}} {{font_size_ui}}";
    t-width:   {{rofi_width}}px;
    t-lines:   {{rofi_lines}};

    background-color: transparent;
    text-color: @fg;
}
