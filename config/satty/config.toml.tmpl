[general]
# {{THEME_NAME}} — generated by `theme`. Do not edit; edit themes/*.theme.
# Start with toolbars visible; annotate then Ctrl+C / Enter to copy+save.
fullscreen = false
corner-roundness = 12
initial-tool = "arrow"
copy-command = "wl-copy"
# Ctrl+C copies to clipboard AND writes the file (matches --save-after-copy).
action-on-enter = "save-to-clipboard"
early-exit = false
output-filename = "~/Pictures/Screenshots/shot-%Y%m%d-%H-%M-%S.png"
save-after-copy = true
default-hide-toolbars = false
primary-highlighter = "block"
disable-notifications = false

[font]
family = "JetBrainsMono Nerd Font"
style = "Bold"

[color-palette]
palette = [
  "#{{red}}",
  "#{{yellow}}",
  "#{{green}}",
  "#{{cyan}}",
  "#{{magenta}}",
  "#{{accent}}",
  "#{{fg}}",
  "#{{bg}}",
]
